{
  "name": "formatarc",
  "version": "0.2.0",
  "description": "Convert JSON, YAML, CSV, Markdown, and HTML from the terminal. Browser-based version at formatarc.com.",
  "keywords": [
    "json",
    "yaml",
    "csv",
    "markdown",
    "html",
    "formatter",
    "converter",
    "json-formatter",
    "yaml-to-json",
    "csv-to-json",
    "csv-to-markdown",
    "markdown-to-html",
    "html-to-markdown",
    "cli"
  ],
  "author": "FormatArc",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/m-naoki-m/formatarc.git"
  },
  "homepage": "https://formatarc.com",
  "type": "module",
  "main": "./dist/converter.js",
  "types": "./dist/converter.d.ts",
  "bin": {
    "formatarc": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "marked": "^18.0.1",
    "papaparse": "^5.5.2",
    "turndown": "^7.2.4",
    "yaml": "^2.8.1"
  },
  "devDependencies": {
    "@types/papaparse": "^5.3.15",
    "@types/turndown": "^5.0.6",
    "typescript": "^5.8.3"
  }
}
